#!/bin/sh

if [ "$1" = "--help" ] || [ "$1" = "" ]; then
    echo ""
    echo "Usage: lemon-stap-monitor <command to attach to>"
    echo ""
    exit 1
fi

echo "Attaching monitor to '$1'..."
echo
stap -g --suppress-time-limits -DMAXMAPENTRIES=10000 -c "$1" ./lemon-stap-monitor.stp 2>&1 | ./lemon-stap-monitor.py

exit 0