#!/usr/bin/python3

"""
This script is now just a wrapper around the lemon-xlet-makepot utility.
It is kept for backwards compatibility as it is currently used by other scripts
(notably the lemon-spices-makepot script found in the 3rd party spices repos).

for usage info type:
lemon-xlet-makepot -h
* Note that the Javascript argument is inverted because previously Javascript files
were not scanned by default, but now are.
"""

import os
import sys

args = sys.argv[1:]
if '-h' in args:
    print("lemon-json-makepot is deprecated - please use lemon-xlet-makepot instead\ntype lemon-xlet-makepot -h for usage information.")
    quit()
if '-i' not in args and '--install' not in args and \
   '-r' not in args and '--remove' not in args:
    potfile = args.pop()
    if '-j' in args:
        args.remove('-j')
    elif '--js' in args:
        args.remove('--js')
    else:
        args.append('-j')

    args.append('-o')
    args.append(potfile)

args.append(os.getcwd())
command = 'lemon-xlet-makepot'
args.insert(0, command)
os.execvp(command, args)
